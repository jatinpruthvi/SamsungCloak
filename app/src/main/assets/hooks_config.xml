        <setting name="orientation_simulation_enabled" type="boolean" default="true" />
        <setting name="transition_delay_ms" type="integer" default="5000" />
        <setting name="auto_rotate_disable_prob" type="float" default="0.30" />
        
        <!-- Grip simulation -->
        <setting name="grip_mode_enabled" type="boolean" default="true" />
        <setting name="one_handed_prob" type="float" default="0.75" />
        <setting name="two_handed_prob" type="float" default="0.65" />
        <setting name="surface_prob" type="float" default="0.35" />
        
        <!-- Palm touch -->
        <setting name="palm_touch_enabled" type="boolean" default="true" />
        <setting name="palm_rejection_failure" type="float" default="0.10" />
        <setting name="edge_ghost_touch_prob" type="float" default="0.035" />
    </hook>

    <!-- Hook 18 Realism: Emotional State Interaction Patterns -->
    <hook id="hook_18_realism" name="EmotionalStateRealism">
        <setting name="enabled" type="boolean" default="true" />
        <setting name="intensity" type="float" default="0.5" min="0.0" max="1.0" />
        
        <!-- Frustration patterns -->
        <setting name="frustration_simulation_enabled" type="boolean" default="true" />
        <setting name="rage_tap_probability" type="float" default="0.20" />

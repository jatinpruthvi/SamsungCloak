    <!-- Hook 07 Realism: Battery Thermal & Performance (IMPROVED) -->
    <hook id="hook_07_realism" name="BatteryThermalRealism">
        <setting name="enabled" type="boolean" default="true" />
        <setting name="intensity" type="float" default="0.5" min="0.0" max="1.0" />
        
        <!-- Samsung Game Booster -->
        <setting name="game_booster_enabled" type="boolean" default="true" />
        <setting name="target_fps" type="integer" default="60" />
        <setting name="thermal_throttle_threshold" type="float" default="40.0" />
        
        <!-- Battery degradation -->
        <setting name="battery_degradation_enabled" type="boolean" default="true" />
        <setting name="degradation_rate" type="float" default="0.008" />
        <setting name="non_linear_factor" type="float" default="1.5" />
        
        <!-- Charging behavior -->
        <setting name="charging_behavior_enabled" type="boolean" default="true" />
        <setting name="fast_charge_watts" type="float" default="20.0" />
        <setting name="trickle_charge_watts" type="float" default="3.5" />
        <setting name="adaptive_charging" type="boolean" default="true" />
        
        <!-- Battery health -->
        <setting name="device_age_months" type="integer" default="6" />
        <setting name="manufacturing_variance" type="float" default="0.0" />
    </hook>

    <!-- Hook 08 Realism: Network Quality & Handover (IMPROVED) -->
    <hook id="hook_08_realism" name="NetworkQualityRealism">
        <setting name="enabled" type="boolean" default="true" />
        <setting name="intensity" type="float" default="0.5" min="0.0" max="1.0" />
        
        <!-- WiFi Assist -->
        <setting name="wifi_assist_enabled" type="boolean" default="true" />
        <setting name="wifi_assist_latency" type="integer" default="300" />
        <setting name="wifi_assist_download" type="float" default="1.0" />
        
        <!-- Captive portal -->
        <setting name="captive_portal_enabled" type="boolean" default="true" />
        <setting name="captive_portal_delay_ms" type="integer" default="3000" />
        
        <!-- Network debouncing -->
        <setting name="debouncing_enabled" type="boolean" default="true" />
        <setting name="debounce_window_ms" type="integer" default="20000" />
        
        <!-- Background restrictions -->
        <setting name="background_restriction_enabled" type="boolean" default="true" />
        <setting name="background_throttle_factor" type="float" default="0.30" />
        
        <!-- Congestion -->
        <setting name="congestion_enabled" type="boolean" default="true" />
        <setting name="peak_hour_multiplier" type="float" default="2.5" />
        
        <!-- VPN effects -->
        <setting name="vpn_effects_enabled" type="boolean" default="true" />
        <setting name="vpn_latency_ms" type="integer" default="100" />
        <setting name="vpn_bandwidth_loss" type="float" default="0.20" />
    </hook>

</hooks_configuration>

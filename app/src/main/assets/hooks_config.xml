    <!-- Hook 19 Realism: App Session & Task Switching Patterns -->
    <hook id="hook_19_realism" name="SessionPatternsRealism">
        <setting name="enabled" type="boolean" default="true" />
        <setting name="intensity" type="float" default="0.5" min="0.0" max="1.0" />
        
        <!-- Session length distribution -->
        <setting name="session_length_enabled" type="boolean" default="true" />
        <setting name="micro_session_percent" type="float" default="0.25" />

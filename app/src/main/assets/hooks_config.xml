        <setting name="touch_and_retract_prob" type="float" default="0.28" />
        <setting name="hesitation_trigger_prob" type="float" default="0.60" />
        
        <!-- Satisfaction patterns -->
        <setting name="satisfaction_simulation_enabled" type="boolean" default="true" />
        <setting name="consistent_tap_variance" type="float" default="0.10" />
        <setting name="smooth_gesture_threshold" type="float" default="0.85" />
        <setting name="long_session_minutes" type="integer" default="15" />
